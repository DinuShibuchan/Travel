# Database configuration (using standard local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_planner

# OpenWeather API Configuration (Use a valid API key, or keep 'dummy' to trigger fallback mocked data)
OPENWEATHER_API_KEY=dummy

# Ollama Local Service Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
